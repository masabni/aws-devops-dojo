{
  "permissions": {
    "allow": [
      "Bash(npm install)",
      "Bash(npm test:*)",
      "Bash(npm run:*)",
      "Bash(docker build:*)",
      "Bash(docker run:*)",
      "Bash(docker ps:*)",
      "Bash(docker images:*)",
      "Bash(terraform fmt:*)",
      "Bash(terraform validate:*)",
      "Bash(terraform init:*)",
      "Bash(terraform plan:*)",
      "Bash(aws sts get-caller-identity)",
      "Bash(aws ecr describe-repositories:*)",
      "Bash(aws ecs describe-services:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)"
    ],
    "ask": [
      "Bash(terraform apply:*)",
      "Bash(terraform destroy:*)",
      "Bash(aws ecs update-service:*)",
      "Bash(docker push:*)"
    ],
    "deny": []
  }
}
