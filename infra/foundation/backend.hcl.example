# Copy to backend.hcl (gitignored) and fill in from the bootstrap stack outputs.
# Then: terraform init -backend-config=backend.hcl
bucket         = "aws-devops-dojo-tfstate-REPLACE-WITH-ACCOUNT-ID"
key            = "foundation/terraform.tfstate"
region         = "eu-central-1"
dynamodb_table = "aws-devops-dojo-tf-locks"
encrypt        = true
